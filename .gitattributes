# Normalize line endings so the working tree matches what CI sees.
#
# Without this, a Windows checkout with core.autocrlf=true converts source
# files to CRLF, and `cargo fmt --all -- --check` then fails locally with
# "Incorrect newline style" even though the committed bytes are correct and
# CI (Linux) is green. Pinning LF removes that whole class of confusion.

* text=auto eol=lf

# Shell scripts must be LF or they will not execute on Linux/macOS.
*.sh text eol=lf

# Binary artifacts — never touch these.
*.wasm binary
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.pdf  binary

# Generated lockfiles: keep them in diffs but collapse them in PR review UIs,
# where a dependency bump otherwise buries the actual change.
Cargo.lock       linguist-generated=true
package-lock.json linguist-generated=true
