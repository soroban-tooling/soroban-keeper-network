# ──────────────────────────────────────────────────────────────
# Soroban Keeper Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────

# Network: testnet | futurenet | mainnet
NETWORK=testnet

# Your keeper's Stellar secret key (starts with S...)
# Fund this account on testnet: https://laboratory.stellar.org/#account-creator
KEEPER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# The deployed KeeperRegistry contract ID
REGISTRY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# How often to poll for new tasks (milliseconds)
POLL_INTERVAL_MS=10000

# Minimum accumulated rewards before auto-withdrawal (in stroops, 1 XLM = 10_000_000)
WITHDRAW_THRESHOLD=10000000

# Maximum tasks to process per poll round (avoids tx queue spam)
MAX_TASKS_PER_ROUND=5
